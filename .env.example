# 支払総額（JACCS 48回無金利の総額。分子はこの固定値）
TOTAL_PRICE_JPY=248310
# 購入日（キラキラ減衰・グラフ起点・JACCS進捗の起点）
PURCHASE_DATE=2026-07-06
# 分割払いの初回引落月（YYYY-MM）
PAYMENT_START_YM=2026-07
# フィルム換算の設定値（いつでも変更可）
FILM_PRICE_JPY=2500
FILM_DEV_PRICE_JPY=1830
FILM_SHOTS_PER_ROLL=24

# Immich 連携（API キーは Immich Web UI → アカウント設定 → API キー で発行）
IMMICH_URL=http://host.docker.internal:2283
IMMICH_API_KEY=
CAMERA_MODEL=X-E5

MAX_UPLOAD_MB=120
